<BorderPane fx:id="mainContents" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: #E8F2FC;" styleClass="root-pane" stylesheets="@/ui/css/report.css, @/ui/css/start_screen.css, @/ui/css/common.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uk.ac.warwick.cs261.ui.controllers.ReportsController">
