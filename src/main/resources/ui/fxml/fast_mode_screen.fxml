<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane
    styleClass="sim-root"
    stylesheets="@/ui/css/common.css, @/ui/css/simulation_screen.css, @/ui/css/settings_modal.css, @/ui/css/fast_mode_screen.css"
    xmlns="http://javafx.com/javafx/25"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="uk.ac.warwick.cs261.ui.controllers.FastModeScreenController">

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="top-bar" BorderPane.alignment="CENTER">
            <Label text="Dorset Software Airport Simulation" styleClass="top-bar__title" />
        </HBox>
    </top>

    <!-- CENTRE: spinner + message -->
    <center>
        <VBox alignment="CENTER" spacing="20">
            <ProgressIndicator
                fx:id="spinner"
                styleClass="loading-spinner"
                prefWidth="72"
                prefHeight="72"
                progress="-1" />
            <Label fx:id="messageLabel"
                   text="Running simulation..."
                   styleClass="loading-label" />
        </VBox>
    </center>

    <!-- BOTTOM: view statistics button -->
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="8" styleClass="loading-footer">
            <padding><Insets top="14" right="20" bottom="14" left="20" /></padding>
            <Button mnemonicParsing="false" 
                    styleClass="loading-quit-btn" 
                    text="Quit"
                    onAction="#quitToStartScreen" />
            <Button fx:id="viewStatisticsButton"
                    mnemonicParsing="false"
                    styleClass="btn, btn--primary, loading-stats-btn"
                    text="View Statistics"
                    onAction="#viewSimulationStatistics"
                    disable="true" />
        </HBox>
    </bottom>

</BorderPane>
