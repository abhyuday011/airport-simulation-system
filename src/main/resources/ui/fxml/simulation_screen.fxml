<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import uk.ac.warwick.cs261.ui.components.ResponsiveHBox?>
<?import uk.ac.warwick.cs261.ui.components.ResponsiveVBox?>
<?import uk.ac.warwick.cs261.ui.components.ResponsiveChild?>
<?import uk.ac.warwick.cs261.ui.components.AircraftTableView?>

<BorderPane
    styleClass="sim-root"
    stylesheets="@/ui/css/common.css, @/ui/css/simulation_screen.css"
    xmlns="http://javafx.com/javafx/25"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="uk.ac.warwick.cs261.ui.controllers.SimulationController">

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="top-bar" BorderPane.alignment="CENTER">
            <Label text="Dorset Software Airport Simulation" styleClass="top-bar__title" />
            <Region HBox.hgrow="ALWAYS" />
            <Label text="Simulation Time:" styleClass="sim-time-label" />
            <Label fx:id="simulationTime" text="00:00:00" styleClass="sim-time-value" />
            <Separator orientation="VERTICAL" styleClass="top-bar__sep" />
            <Label text="Est. Duration:" styleClass="sim-time-label" />
            <Label fx:id="simulationDuration" text="24:00:00" styleClass="sim-time-value" />
            <Region prefWidth="8" />
            <Button visible="false" fx:id="statsSummary" onAction="#statSummary" mnemonicParsing="false" styleClass="btn--top-bar" text="Stats Summary" />
            <Button styleClass="btn--top-bar" onAction="#showSettingsModal" fx:id="fastBtn" mnemonicParsing="false" text="  Settings  " />
            <Button styleClass="pause" onAction="#pause" fx:id="pauseBtn" mnemonicParsing="false" text="  Pause  " />
            <Button mnemonicParsing="false" onAction="#help" styleClass="btn--top-bar" text="Help" />
        </HBox>
    </top>

    <center>
        <ResponsiveHBox spacing="0">

            <!-- 60%: simulation column -->
            <ResponsiveChild relativeSize="0.65">
                <ResponsiveVBox spacing="0">

                    <!-- 75%: queues + runways -->
                    <ResponsiveChild relativeSize="0.75">
                        <HBox alignment="CENTER" spacing="12" styleClass="sim-main-area">

                            <!-- Holding queue -->
                            <VBox HBox.hgrow="NEVER" prefWidth="110" minWidth="110" maxWidth="110"
                                  styleClass="queue-box" spacing="0" onMouseClicked="#showHoldingQueueModal">
                                <VBox styleClass="queue-box__header" alignment="CENTER" maxWidth="Infinity">
                                    <Label text="Holding Queue" styleClass="queue-box__label" maxWidth="Infinity" />
                                </VBox>
                                <ScrollPane styleClass="scroll-pane"
                                            fitToWidth="true" fitToHeight="true"
                                            hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                            VBox.vgrow="ALWAYS">
                                    <content>
                                        <VBox fx:id="holdingQueue" alignment="TOP_CENTER" spacing="4" />
                                    </content>
                                </ScrollPane>
                            </VBox>

                            <!-- Runways + takeoff queue -->
                            <ResponsiveVBox 
                            alignment="TOP_CENTER" spacing="10"
                                  HBox.hgrow="ALWAYS" styleClass="sim-runway-area">
                                <ResponsiveChild relativeSize="0.75">
                                <FlowPane fx:id="runwayBoxes" styleClass="runway-box-list" alignment="CENTER" hgap="8" vgap="10"/>
                                </ResponsiveChild>
                                <ResponsiveChild relativeSize="0.25">
                                <VBox styleClass="queue-box" spacing="0"
                                      prefHeight="110" minHeight="110" maxHeight="110"
                                      onMouseClicked="#showTakeoffQueueModal">
                                    <HBox styleClass="queue-box__header" alignment="CENTER_LEFT" spacing="8" maxWidth="Infinity">
                                        <Label text="Takeoff Queue" styleClass="queue-box__label" />
                                    </HBox>
                                    <ScrollPane styleClass="scroll-pane"
                                                fitToHeight="true" fitToWidth="true"
                                                vbarPolicy="NEVER" hbarPolicy="AS_NEEDED"
                                                VBox.vgrow="ALWAYS">
                                        <content>
                                            <HBox fx:id="takeoffQueue" alignment="CENTER_LEFT" spacing="4" />
                                        </content>
                                    </ScrollPane>
                                </VBox>
                                </ResponsiveChild>
                            </ResponsiveVBox>

                        </HBox>
                    </ResponsiveChild>

                    <!-- 25%: Events + Live Statistics -->
                    <ResponsiveChild relativeSize="0.25">
                        <ResponsiveHBox styleClass="sim-bottom-panels" spacing="0" prefHeight="180">

                            <ResponsiveChild relativeSize="0.5">
                                <VBox styleClass="sim-events-panel" spacing="8" HBox.hgrow="ALWAYS" prefWidth="400">
                                    <padding><Insets top="12" right="12" bottom="12" left="16" /></padding>
                                    <Label text="Events" styleClass="section-header" />
                                    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                                        <content>
                                            <VBox fx:id="eventsList" spacing="4" />
                                        </content>
                                    </ScrollPane>
                                </VBox>
                            </ResponsiveChild>

                            <ResponsiveChild relativeSize="0.5">
                                <VBox styleClass="sim-stats-panel" spacing="8" HBox.hgrow="ALWAYS" prefWidth="350">
                                    <padding><Insets top="12" right="12" bottom="12" left="16" /></padding>
                                    <Label text="Live Statistics" styleClass="section-header" />
                                    <VBox spacing="6" VBox.vgrow="ALWAYS">
                                        <HBox spacing="10">
                                            <Label text="Total Aircraft:" styleClass="field-label stat-label" prefWidth="180" />
                                            <Label fx:id="totalAircraft" text="7" styleClass="stat-value" />
                                        </HBox>
                                        <HBox spacing="10">
                                            <Label text="Max. Holding Queue Size:" styleClass="field-label stat-label" prefWidth="180" />
                                            <Label fx:id="hQueueSize" text="4" styleClass="stat-value" />
                                        </HBox>
                                        <HBox spacing="10">
                                            <Label text="Avg. Holding Size:" styleClass="field-label stat-label" prefWidth="180" />
                                            <Label fx:id="avgHolding" text="7" styleClass="stat-value" />
                                        </HBox>
                                        <HBox spacing="10">
                                            <Label text="Max. Takeoff Queue Size:" styleClass="field-label stat-label" prefWidth="180" />
                                            <Label fx:id="tQueueSize" text="5" styleClass="stat-value" />
                                        </HBox>
                                        <HBox spacing="10">
                                            <Label text="Avg. Takeoff Size:" styleClass="field-label stat-label" prefWidth="180" />
                                            <Label fx:id="avgTakeoff" text="7" styleClass="stat-value" />
                                        </HBox>
                                    </VBox>
                                </VBox>
                            </ResponsiveChild>

                        </ResponsiveHBox>
                    </ResponsiveChild>

                </ResponsiveVBox>
            </ResponsiveChild>

            <!-- 40%: Flight queue table -->
            <ResponsiveChild relativeSize="0.35">
                <VBox styleClass="flight-queue-panel" spacing="0">
                    <Label text="Flight Queue" maxWidth="Infinity" styleClass="flight-queue-panel__header" />
                    <AircraftTableView fx:id="flightTable" VBox.vgrow="ALWAYS" styleClass="timetable-table" />
                </VBox>
            </ResponsiveChild>

        </ResponsiveHBox>
    </center>

</BorderPane>
